generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  citizen
  volunteer
  admin
}

enum LanguagePref {
  en
  bn
}

enum VolunteerAvailability {
  available
  busy
  offline
}

enum EmergencyType {
  flood
  cyclone
  landslide
  fire
  other
}

enum IncidentType {
  flood
  cyclone
  landslide
  fire
  building_collapse
  other
}

enum SOSStatus {
  pending
  acknowledged
  in_progress
  resolved
  cancelled
}

enum ReportStatus {
  submitted
  verified
  rejected
}

enum ShelterStatus {
  open
  full
  closed
}

enum TaskStatus {
  pending
  accepted
  in_progress
  completed
  cancelled
}

enum ReliefType {
  food
  water
  medicine
  clothing
  shelter
  other
}

enum Urgency {
  low
  medium
  high
  critical
}

enum ReliefStatus {
  pending
  approved
  rejected
  dispatched
  delivered
}

enum DeliveryStatus {
  preparing
  in_transit
  delivered
}

enum NotificationType {
  sos
  alert
  task
  relief
  system
}

enum AlertSeverity {
  info
  warning
  danger
}

model User {
  id           Int          @id @default(autoincrement())
  name         String       @db.VarChar(100)
  email        String       @unique @db.VarChar(150)
  phone        String?      @unique @db.VarChar(20)
  passwordHash String       @map("password_hash") @db.VarChar(255)
  role         UserRole     @default(citizen)
  avatarUrl    String?      @map("avatar_url") @db.VarChar(500)
  languagePref LanguagePref @default(en) @map("language_pref")
  latitude     Decimal?     @db.Decimal(10, 8)
  longitude    Decimal?     @db.Decimal(11, 8)
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  sosRequests          SOSRequest[]
  disasterReports      DisasterReport[]
  reliefRequests       ReliefRequest[]
  volunteer            Volunteer?
  notifications        Notification[]
  shelterCreated       Shelter[]
  adminAlerts          AdminAlert[]
  volunteerAssignments VolunteerAssignment[] @relation("AssignedBy")
  reliefApprovals      ReliefDistribution[]  @relation("ApprovedBy")

  @@map("users")
}

model Volunteer {
  id           Int                   @id @default(autoincrement())
  userId       Int                   @unique @map("user_id")
  skills       String?               @db.VarChar(500)
  availability VolunteerAvailability @default(offline)
  verified     Boolean               @default(false)
  latitude     Decimal?              @db.Decimal(10, 8)
  longitude    Decimal?              @db.Decimal(11, 8)
  updatedAt    DateTime              @updatedAt @map("updated_at")

  user                User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignments         VolunteerAssignment[]
  reliefDistributions ReliefDistribution[]

  @@map("volunteers")
}

model SOSRequest {
  id            Int           @id @default(autoincrement())
  userId        Int           @map("user_id")
  emergencyType EmergencyType @map("emergency_type")
  severity      Int
  description   String?       @db.Text
  latitude      Decimal       @db.Decimal(10, 8)
  longitude     Decimal       @db.Decimal(11, 8)
  status        SOSStatus     @default(pending)
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  user       User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignment VolunteerAssignment?

  @@index([userId])
  @@index([status])
  @@map("sos_requests")
}

model DisasterReport {
  id           Int          @id @default(autoincrement())
  userId       Int          @map("user_id")
  incidentType IncidentType @map("incident_type")
  description  String       @db.Text
  imageUrl     String?      @map("image_url") @db.VarChar(500)
  latitude     Decimal      @db.Decimal(10, 8)
  longitude    Decimal      @db.Decimal(11, 8)
  verified     Boolean      @default(false)
  status       ReportStatus @default(submitted)
  createdAt    DateTime     @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("disaster_reports")
}

model Shelter {
  id               Int           @id @default(autoincrement())
  name             String        @db.VarChar(200)
  address          String        @db.Text
  latitude         Decimal       @db.Decimal(10, 8)
  longitude        Decimal       @db.Decimal(11, 8)
  capacity         Int
  currentOccupancy Int           @default(0) @map("current_occupancy")
  contactPhone     String?       @map("contact_phone") @db.VarChar(20)
  status           ShelterStatus @default(open)
  createdBy        Int?          @map("created_by")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  createdByUser User? @relation(fields: [createdBy], references: [id])

  @@index([status])
  @@map("shelters")
}

model VolunteerAssignment {
  id           Int        @id @default(autoincrement())
  volunteerId  Int        @map("volunteer_id")
  sosRequestId Int?       @unique @map("sos_request_id")
  taskType     String     @map("task_type") @db.VarChar(50)
  description  String?    @db.Text
  status       TaskStatus @default(pending)
  assignedBy   Int        @map("assigned_by")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  volunteer      Volunteer   @relation(fields: [volunteerId], references: [id], onDelete: Cascade)
  sosRequest     SOSRequest? @relation(fields: [sosRequestId], references: [id], onDelete: SetNull)
  assignedByUser User        @relation("AssignedBy", fields: [assignedBy], references: [id])

  @@index([volunteerId])
  @@index([status])
  @@map("volunteer_assignments")
}

model ReliefRequest {
  id          Int          @id @default(autoincrement())
  userId      Int          @map("user_id")
  reliefType  ReliefType   @map("relief_type")
  quantity    String       @db.VarChar(100)
  urgency     Urgency      @default(medium)
  description String?      @db.Text
  latitude    Decimal?     @db.Decimal(10, 8)
  longitude   Decimal?     @db.Decimal(11, 8)
  status      ReliefStatus @default(pending)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  user          User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  distributions ReliefDistribution[]

  @@index([userId])
  @@index([status])
  @@map("relief_requests")
}

model ReliefDistribution {
  id              Int            @id @default(autoincrement())
  reliefRequestId Int            @map("relief_request_id")
  volunteerId     Int?           @map("volunteer_id")
  approvedBy      Int            @map("approved_by")
  deliveryStatus  DeliveryStatus @default(preparing) @map("delivery_status")
  notes           String?        @db.Text
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  reliefRequest  ReliefRequest @relation(fields: [reliefRequestId], references: [id], onDelete: Cascade)
  volunteer      Volunteer?    @relation(fields: [volunteerId], references: [id], onDelete: SetNull)
  approvedByUser User          @relation("ApprovedBy", fields: [approvedBy], references: [id])

  @@index([reliefRequestId])
  @@index([volunteerId])
  @@map("relief_distributions")
}

model Notification {
  id        Int              @id @default(autoincrement())
  userId    Int              @map("user_id")
  title     String           @db.VarChar(200)
  message   String           @db.Text
  type      NotificationType @default(system)
  isRead    Boolean          @default(false) @map("is_read")
  createdAt DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}

model WeatherLog {
  id          Int      @id @default(autoincrement())
  district    String   @db.VarChar(100)
  temperature Decimal? @db.Decimal(5, 2)
  humidity    Decimal? @db.Decimal(5, 2)
  windSpeed   Decimal? @map("wind_speed") @db.Decimal(5, 2)
  rainfall    Decimal? @db.Decimal(7, 2)
  waterLevel  Decimal? @map("water_level") @db.Decimal(7, 2)
  description String?  @db.VarChar(200)
  fetchedAt   DateTime @default(now()) @map("fetched_at")

  predictions RiskPrediction[]

  @@index([district])
  @@index([fetchedAt])
  @@map("weather_logs")
}

model RiskPrediction {
  id           Int      @id @default(autoincrement())
  district     String   @db.VarChar(100)
  riskScore    Decimal  @map("risk_score") @db.Decimal(4, 3)
  riskCategory String   @map("risk_category") @db.VarChar(20)
  explanation  String?  @db.Text
  weatherLogId Int?     @map("weather_log_id")
  createdAt    DateTime @default(now()) @map("created_at")

  weatherLog WeatherLog? @relation(fields: [weatherLogId], references: [id])

  @@index([district])
  @@index([createdAt])
  @@map("risk_predictions")
}

model AdminAlert {
  id         Int           @id @default(autoincrement())
  createdBy  Int           @map("created_by")
  title      String        @db.VarChar(200)
  message    String        @db.Text
  severity   AlertSeverity @default(info)
  targetArea String?       @map("target_area") @db.VarChar(200)
  isActive   Boolean       @default(true) @map("is_active")
  createdAt  DateTime      @default(now()) @map("created_at")
  expiresAt  DateTime?     @map("expires_at")

  creator User @relation(fields: [createdBy], references: [id])

  @@index([isActive])
  @@index([createdAt])
  @@map("admin_alerts")
}
